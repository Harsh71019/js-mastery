{
  "name": "js-trainer-server",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "convert": "ts-node-dev --transpile-only src/convert.ts",
    "seed": "ts-node-dev --transpile-only src/seed.ts",
    "list-titles": "ts-node-dev --transpile-only src/list-titles.ts",
    "seed-mcq": "ts-node-dev --transpile-only src/seed-mcq.ts",
    "seed-trick": "ts-node-dev --transpile-only src/seed-trick.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "mongoose": "^8.4.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
